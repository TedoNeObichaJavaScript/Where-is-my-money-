# --- Android / Gradle ---
*.iml
.gradle/
.kotlin/
.idea/
.DS_Store
.externalNativeBuild
.cxx/
captures/

# Build outputs
build/
**/build/
release/
/app/release/

# Local config (machine-specific)
local.properties

# Signing
*.keystore
*.jks
!debug.keystore

# --- Local-only assets (screenshots, ADB dumps, scratch) ---
.local-assets/
*.png
*.jpg
*.jpeg
window_dump.xml
!.github/assets/*.svg
!.github/assets/*.png
!app/src/**/*.png
!app/src/**/*.jpg
!app/src/**/*.webp

# --- React Native / Expo (mobile/) ---
node_modules/
mobile/.expo/
mobile/dist/
mobile/ios/
mobile/android/
expo-env.d.ts
# allow committed mobile design assets despite the global *.png ignore above
!mobile/assets/**/*.png
!mobile/assets/**/*.jpg
!mobile/assets/**/*.webp

# OS / editors
Thumbs.db
*.swp
*.bak
