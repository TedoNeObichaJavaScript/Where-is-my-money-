# --- OS / editors ---
.idea/
.DS_Store
Thumbs.db
*.swp
*.bak

# --- React Native / Expo (mobile/) ---
node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/ios/
mobile/android/
expo-env.d.ts
.metro-health-check*

# --- Build / native artifacts ---
build/
**/build/
.gradle/
.cxx/
.externalNativeBuild

# --- Secrets / signing (never commit) ---
*.keystore
*.jks
!debug.keystore
*.p8
*.p12
*.mobileprovision
local.properties
google-services.json
GoogleService-Info.plist
.env
.env.*

# --- Local-only assets (screenshots, scratch) ---
.local-assets/
*.png
*.jpg
*.jpeg
window_dump.xml
# allow committed design assets despite the global image ignore above
!.github/assets/**/*.png
!.github/assets/**/*.svg
!mobile/assets/**/*.png
!mobile/assets/**/*.jpg
!mobile/assets/**/*.webp
