{
  "expo": {
    "name": "Where Is My Money?",
    "slug": "parite",
    "scheme": "parite",
    "version": "0.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "bg.parite.app",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock Parite with Face ID to keep your finances private."
      }
    },
    "android": {
      "package": "bg.parite.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1216"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      [
        "expo-build-properties",
        {
          "android": { "compileSdkVersion": 35, "targetSdkVersion": 35 }
        }
      ],
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Unlock Parite with Face ID to keep your finances private."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F1216",
          "image": "./assets/icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
