<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="parite.db" />
        <exclude domain="database" path="parite.db-journal" />
        <exclude domain="database" path="parite.db-wal" />
        <exclude domain="database" path="parite.db-shm" />
        <exclude domain="sharedpref" path="parite_secure.xml" />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="parite.db" />
        <exclude domain="sharedpref" path="parite_secure.xml" />
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
